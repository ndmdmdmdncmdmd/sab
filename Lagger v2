-- ========== СОЗДАНИЕ BLUR ЭФФЕКТА НА ФОН ==========
local function createBlurEffect()
    local lighting = game:GetService("Lighting")
    blurEffect = lighting:FindFirstChild("BlurEffect")
    
    if not blurEffect then
        blurEffect = Instance.new("BlurEffect")
        blurEffect.Name = "BlurEffect"
        blurEffect.Size = 0
        blurEffect.Parent = lighting
    end
    return blurEffect
end

local function showBlur(duration, targetSize)
    duration = duration or 0.3
    targetSize = targetSize or 12
    
    if not blurEffect then
        createBlurEffect()
    end
    
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = tweenService:Create(blurEffect, tweenInfo, {Size = targetSize})
    tween:Play()
end

local function hideBlur(duration)
    duration = duration or 0.3
    
    if blurEffect then
        local tweenService = game:GetService("TweenService")
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        local tween = tweenService:Create(blurEffect, tweenInfo, {Size = 0})
        tween:Play()
    end
end

