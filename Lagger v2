local function getCurrentColor()
    local colors = {
        {Color3.new(1, 0.2, 1), "Bright violet", "💜"},
        {Color3.new(0, 0.5, 1), "Electric blue", "💙"},
        {Color3.new(1, 0.2, 0), "Really red", "❤️"},
        {Color3.new(0, 1, 1), "Cyan", "💚"},
        {Color3.new(1, 0.8, 0), "Gold", "💛"},
    }
    
    if currentColor == 6 then
        return colors[math.random(#colors)]
    end
    return colors[currentColor]
end

-- ========== МЕГА МЕТОД ==========
local function createMegaEffect(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    local targetPos = target.Character.HumanoidRootPart.Position
    local colorData = getCurrentColor()
    local mainColor = colorData[1]
    local brickColor = BrickColor.new(colorData[2])
    
    -- Создаём множество разных эффектов
    
    -- 1. Сферы (5 штук)
    for i = 1, 5 do
        local sphere = Instance.new("Part")
        sphere.Size = Vector3.new(2.5, 2.5, 2.5)
        sphere.Shape = Enum.PartType.Ball
        sphere.BrickColor = brickColor
        sphere.Material = Enum.Material.Neon
        sphere.Anchored = true
        sphere.CanCollide = true
        sphere.Parent = workspace
        sphere:SetAttribute("IsOurPart", true)
        
        local light = Instance.new("PointLight")
        light.Color = mainColor
        light.Range = 20
        light.Brightness = 3
        light.Parent = sphere
        
        sphere.Position = targetPos + Vector3.new(
            math.random(-25, 25),
            math.random(-5, 20),
            math.random(-25, 25)
        )
        sphere.RotVelocity = Vector3.new(math.random(-50, 50), math.random(-50, 50), math.random(-50, 50))
        table.insert(createdParts, sphere)
    end
    
    -- 2. Столбы (3 штуки)
    for i = 1, 3 do
        local pillar = Instance.new("Part")
        pillar.Size = Vector3.new(1.2, 25, 1.2)
        pillar.BrickColor = brickColor
        pillar.Material = Enum.Material.Neon
        pillar.Anchored = true
        pillar.CanCollide = true
        pillar.Parent = workspace
        pillar:SetAttribute("IsOurPart", true)
        
        local light = Instance.new("PointLight")
        light.Color = mainColor
        light.Range = 25
        light.Brightness = 3.5
        light.Parent = pillar
        
        pillar.Position = targetPos + Vector3.new(
            math.random(-20, 20),
            10,
            math.random(-20, 20)
        )
        table.insert(createdParts, pillar)
    end
    
    -- 3. Кристаллы (6 штук)
    for i = 1, 6 do
        local crystal = Instance.new("Part")
        crystal.Size = Vector3.new(1.2, 1.2, 1.2)
        crystal.Shape = Enum.PartType.Block
        crystal.BrickColor = brickColor
        crystal.Material = Enum.Material.Neon
        crystal.Anchored = true
        crystal.CanCollide = true
        crystal.Parent = workspace
        crystal:SetAttribute("IsOurPart", true)
        
        local light = Instance.new("PointLight")
        light.Color = mainColor
        light.Range = 16
        light.Brightness = 3
        light.Parent = crystal
        
        crystal.Position = targetPos + Vector3.new(
            math.random(-18, 18),
            math.random(0, 12),
            math.random(-18, 18)
        )
        crystal.RotVelocity = Vector3.new(math.random(-30, 30), math.random(-30, 30), math.random(-30, 30))
        table.insert(createdParts, crystal)
    end
    
    -- 4. Кольца (2 штуки)
    for i = 1, 2 do
        local ring = Instance.new("Part")
        ring.Size = Vector3.new(12, 0.8, 12)
        ring.BrickColor = brickColor
        ring.Material = Enum.Material.Neon
        ring.Anchored = true
        ring.CanCollide = true
        ring.Parent = workspace
        ring:SetAttribute("IsOurPart", true)
        
        local light = Instance.new("PointLight")
        light.Color = mainColor
        light.Range = 24
        light.Brightness = 3
        light.Parent = ring
        
        ring.Position = targetPos + Vector3.new(
            math.random(-8, 8),
            math.random(-3, 10),
            math.random(-8, 8)
        )
        ring.RotVelocity = Vector3.new(0, math.random(100, 200), 0)
        table.insert(createdParts, ring)
    end
    
    partsInfo.Text = getText("parts_count") .. ": " .. #createdParts
end

-- ========== ОСНОВНОЙ ЦИКЛ ==========
local function startLagging()
    if not selectedTarget then
        statusLabel.Text = getText("status_error")
        statusLabel.TextColor3 = Color3.new(1, 0, 0)
        return
    end
    
    if lagging then
        stopAndClear()
        wait(0.5)
    end
    
    lagging = true
    startBtn.BackgroundColor3 = Color3.new(0, 1, 0)
    statusLabel.Text = getText("status_lagging") .. " " .. string.upper(selectedTarget.Name)
    statusLabel.TextColor3 = Color3.new(1, 0.5, 0)
    
    spawn(function()
        while lagging do
            if not selectedTarget or not selectedTarget.Parent then
                statusLabel.Text = getText("status_target_left")
                lagging = false
                break
            end
            
            if not selectedTarget.Character or not selectedTarget.Character:FindFirstChild("HumanoidRootPart") then
                wait(0.5)
                goto continue
            end
            
            pcall(createMegaEffect, selectedTarget)
            wait(0.15)
            
            ::continue::
        end
        
        startBtn.BackgroundColor3 = Color3.new(1, 0, 0)
        if not selectedTarget or not selectedTarget.Parent then
            statusLabel.Text = getText("status_target_left")
        else
            statusLabel.Text = getText("status_stopped")
        end
        statusLabel.TextColor3 = Color3.new(0, 1, 0)
        wait(1.5)
        if not lagging then
            statusLabel.Text = getText("status_ready")
        end
    end)
end

-- ========== ОЧИСТКА ==========
local function clearAllParts()
    local count = 0
    for _, part in pairs(createdParts) do
        if part and part.Parent then
            pcall(function() part:Destroy() end)
            count = count + 1
        end
    end
    createdParts = {}
    partsInfo.Text = getText("parts_count") .. ": 0"
    
    if count > 0 then
        statusLabel.Text = getText("status_cleared") .. " " .. count .. " " .. getText("parts_count"):match("%S+$") or ""
        statusLabel.TextColor3 = Color3.new(1, 1, 0)
        wait(1)
        if not lagging then
            statusLabel.Text = getText("status_ready")
            statusLabel.TextColor3 = Color3.new(0, 1, 0)
        end
    end
    return count
end

local function stopAndClear()
    lagging = false
    local cleared = clearAllParts()
    startBtn.BackgroundColor3 = Color3.new(1, 0, 0)
    statusLabel.Text = cleared > 0 and getText("status_stopped") .. " " .. getText("status_cleared"):match("^[^%d]+") .. cleared or getText("status_stopped")
    statusLabel.TextColor3 = Color3.new(0, 1, 0)
    wait(1.5)
    if not lagging then
        statusLabel.Text = getText("status_ready")
    end
end

-- ========== ПРОХОД ЧЕРЕЗ БЛОКИ ==========
local function enablePassThrough()
    noclipActive = true
    noclipBtn.BackgroundColor3 = Color3.new(0, 0.8, 0)
    noclipBtn.Text = getText("noclip_on")
    
    if selectedTarget and selectedTarget.Character then
        for _, ourPart in pairs(createdParts) do
            if ourPart and ourPart.Parent then
                pcall(function()
                    ourPart:SetAttribute("GhostFor", selectedTarget.Name)
                end)
            end
        end
        statusLabel.Text = getText("status_noclip_on")
    else
        statusLabel.Text = getText("status_no_target")
    end
    statusLabel.TextColor3 = Color3.new(0, 1, 0)
    wait(1.5)
    if not lagging then
        statusLabel.Text = getText("status_ready")
    end
end

local function disablePassThrough()
    noclipActive = false
    noclipBtn.BackgroundColor3 = Color3.new(0.3, 0.3, 0.8)
    noclipBtn.Text = getText("noclip")
    
    if selectedTarget and selectedTarget.Character then
        for _, ourPart in pairs(createdParts) do
            if ourPart and ourPart.Parent then
                pcall(function()
                    ourPart:SetAttribute("GhostFor", nil)
                end)
            end
        end
    end
    statusLabel.Text = getText("status_noclip_off")
    statusLabel.TextColor3 = Color3.new(0, 1, 0)
    wait(1.5)
    if not lagging then
        statusLabel.Text = getText("status_ready")
    end
end

-- ========== ОБНОВЛЕНИЕ СПИСКА ==========
local function updatePlayerList()
    for _, child in pairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 45)
            btn.Text = "👤 " .. plr.Name
            btn.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.TextScaled = true
            btn.Parent = playerList
            
            btn.MouseButton1Click:Connect(function()
                if lagging then
                    stopAndClear()
                end
                
                selectedTarget = plr
                
                for _, b in pairs(playerList:GetChildren()) do
                    if b:IsA("TextButton") then
                        b.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
                    end
                end
                btn.BackgroundColor3 = Color3.new(1, 0.2, 0.5)
                targetLabel.Text = getText("target"):gsub("НЕ ВЫБРАНА|NOT SELECTED", string.upper(plr.Name))
                targetLabel.Text = targetLabel.Text:gsub("🎯 ЦЕЛЬ:", "🎯 " .. getText("target"):match("^[^:]+"):gsub("🎯", "") .. ":")
                targetLabel.Text = targetLabel.Text:gsub("TARGET:", "TARGET:")
                targetLabel.Text = "🎯 " .. (language == "RU" and "ЦЕЛЬ: " or "TARGET: ") .. string.upper(plr.Name)
                statusLabel.Text = getText("status_select")
                statusLabel.TextColor3 = Color3.new(0, 1, 0)
                
                if noclipActive then
                    for _, ourPart in pairs(createdParts) do
                        if ourPart and ourPart.Parent then
                            pcall(function()
                                ourPart:SetAttribute("GhostFor", plr.Name)
                            end)
                        end
                    end
                end
            end)
        end
    end
end

-- ========== ОБНОВЛЕНИЕ ТЕКСТА ==========
local function updateLanguage()
    title.Text = getText("title")
    listTitle.Text = getText("players")
    targetLabel.Text = "🎯 " .. (language == "RU" and "ЦЕЛЬ: " or "TARGET: ") .. (selectedTarget and string.upper(selectedTarget.Name) or (language == "RU" and "НЕ ВЫБРАНА" or "NOT SELECTED"))
    
    if noclipActive then
        noclipBtn.Text = getText("noclip_on")
    else
        noclipBtn.Text = getText("noclip")
    end
    
    settingsTitle.Text = getText("settings")
    
    local colorNames = {
        getText("color_purple"),
        getText("color_blue"),
        getText("color_red"),
        getText("color_cyan"),
        getText("color_gold"),
        getText("color_random")
    }
    colorBtn.Text = getText("color") .. ": " .. colorNames[currentColor]
    
    langBtn.Text = language == "RU" and getText("language_btn") or getText("language_ru")
    
    startBtn.Text = getText("start")
    stopBtn.Text = getText("stop")
    clearBtn.Text = getText("clear")
    partsInfo.Text = getText("parts_count") .. ": " .. #createdParts
    
    if lagging then
        statusLabel.Text = getText("status_lagging") .. " " .. (selectedTarget and string.upper(selectedTarget.Name) or "")
    elseif #createdParts > 0 then
        statusLabel.Text = getText("status_ready")
    else
        statusLabel.Text = getText("status_ready")
    end
end

