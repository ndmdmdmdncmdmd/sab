-- ========== ЛЕТАЮЩИЕ СВЕТЯШКИ В МЕНЮ ==========
local function createFloatingStar(parent)
    local star = Instance.new("TextLabel")
    star.Size = UDim2.new(0, math.random(15, 25), 0, math.random(15, 25))
    star.Position = UDim2.new(math.random(), 0, -0.1, 0)
    star.BackgroundColor3 = Color3.new(1, 1, 1)
    star.BackgroundTransparency = math.random(30, 70) / 100
    star.Text = "✨"
    star.TextColor3 = Color3.new(1, 1, 0.5)
    star.TextSize = math.random(12, 20)
    star.TextScaled = true
    star.Font = Enum.Font.Gotham
    star.Parent = parent
    
    local speed = math.random(20, 50) / 100
    local rotation = math.random(-180, 180)
    
    table.insert(stars, {star = star, speed = speed, rotation = rotation})
    
    return star
end

-- Анимация звёзд
local function animateStars()
    spawn(function()
        while true do
            for i = #stars, 1, -1 do
                local data = stars[i]
                if data and data.star and data.star.Parent then
                    local newY = data.star.Position.Y.Scale + (data.speed / 100)
                    data.star.Position = UDim2.new(data.star.Position.X.Scale, 0, newY, 0)
                    data.star.Rotation = data.star.Rotation + data.rotation / 10
                    
                    -- Если звезда ушла за нижний край, удаляем
                    if newY > 1.1 then
                        data.star:Destroy()
                        table.remove(stars, i)
                    end
                else
                    table.remove(stars, i)
                end
            end
            wait(0.05)
        end
    end)
end

-- Создание новых звёзд
local function spawnStars(parent)
    spawn(function()
        while parent and parent.Parent do
            if math.random(1, 100) > 70 then
                createFloatingStar(parent)
            end
            wait(0.5)
        end
    end)
end

