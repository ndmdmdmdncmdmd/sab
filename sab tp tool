-- Функция обновления метки позиции
local function updatePosLabel()
    if savedPosition then
        PosLabel.Text = string.format("Pos: X=%.1f Y=%.1f Z=%.1f", 
            savedPosition.X, savedPosition.Y, savedPosition.Z)
        PosLabel.TextColor3 = Color3.new(0, 1, 0)
    else
        PosLabel.Text = "No position saved"
        PosLabel.TextColor3 = Color3.new(1, 0, 0)
    end
end

-- Функция уведомления
local function notify(msg, color)
    local notification = Instance.new("TextLabel")
    notification.Parent = ScreenGui
    notification.BackgroundColor3 = color
    notification.BackgroundTransparency = 0.3
    notification.Position = UDim2.new(0.35, 0, 0.45, 0)
    notification.Size = UDim2.new(0.3, 0, 0.1, 0)
    notification.Text = msg
    notification.TextColor3 = Color3.new(1, 1, 1)
    notification.TextScaled = true
    notification.ZIndex = 10
    
    game:GetService("TweenService"):Create(
        notification,
        TweenInfo.new(2),
        {BackgroundTransparency = 1, TextTransparency = 1}
    ):Play()
    
    wait(2)
    notification:Destroy()
end

-- Сохранение
local function savePosition()
    local character = player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        savedPosition = character.HumanoidRootPart.Position
        updatePosLabel()
        notify("✅ Position saved! (Press O to teleport)", Color3.new(0, 1, 0))
        
        -- Эффект на кнопке
        SaveBtn.BackgroundColor3 = Color3.new(0, 1, 0)
        wait(0.2)
        SaveBtn.BackgroundColor3 = Color3.new(0, 0.7, 0)
    end
end

-- Телепортация
local function loadPosition()
    if savedPosition then
        local character = player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = CFrame.new(savedPosition)
            notify("🌀 Teleported to saved position!", Color3.new(0, 1, 1))
            
            LoadBtn.BackgroundColor3 = Color3.new(1, 1, 0)
            wait(0.2)
            LoadBtn.BackgroundColor3 = Color3.new(0.7, 0.7, 0)
        end
    else
        notify("❌ No position saved! Press P first", Color3.new(1, 0, 0))
    end
end

-- Кнопки мыши
SaveBtn.MouseButton1Click:Connect(savePosition)
LoadBtn.MouseButton1Click:Connect(loadPosition)

CloseBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    ToggleBtn.Visible = true
end)

ToggleBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = true
    ToggleBtn.Visible = false
end)

-- Горячие клавиши
game:GetService("UserInputService").InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.P then
        savePosition()
    elseif input.KeyCode == Enum.KeyCode.O then
        loadPosition()
    elseif input.KeyCode == Enum.KeyCode.H then
        MainFrame.Visible = not MainFrame.Visible
        ToggleBtn.Visible = not MainFrame.Visible
    end
end)

print("Script loaded! Use P to save, O to teleport")
