-- Функция телепортации
local function teleport(direction)
    local character = player.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local newPosition = hrp.Position
    
    if direction == "forward" then
        newPosition = hrp.Position + hrp.CFrame.LookVector * teleportDistance
    elseif direction == "backward" then
        newPosition = hrp.Position - hrp.CFrame.LookVector * teleportDistance
    elseif direction == "up" then
        newPosition = hrp.Position + Vector3.new(0, teleportDistance, 0)
    elseif direction == "down" then
        newPosition = hrp.Position - Vector3.new(0, teleportDistance, 0)
    end
    
    -- Проверка на стены (опционально, можно отключить если хотите всегда проходить)
    if noclipEnabled then
        -- С отключенной физикой проходим всегда
        hrp.CFrame = CFrame.new(newPosition)
        Status.Text = "✅ Телепорт (noclip): " .. teleportDistance .. " studs"
    else
        -- Пытаемся телепортироваться даже сквозь стены (игнорируем коллизию)
        hrp.CFrame = CFrame.new(newPosition)
        Status.Text = "✅ Телепорт сквозь стены: " .. teleportDistance .. " studs"
    end
    
    -- Визуальный эффект
    Status.TextColor3 = Color3.new(0, 1, 0)
    wait(0.5)
    Status.TextColor3 = Color3.new(1, 1, 1)
end

-- Noclip функция
local function toggleNoclip()
    noclipEnabled = not noclipEnabled
    
    if noclipEnabled then
        NoclipBtn.Text = "🚫 NOCLIP ON"
        NoclipBtn.BackgroundColor3 = Color3.new(0, 0.8, 0)
        Status.Text = "Noclip включен - проходим сквозь всё"
        
        -- Постоянный noclip
        spawn(function()
            while noclipEnabled do
                local character = player.Character
                if character then
                    for _, part in pairs(character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
                wait(0.1)
            end
        end)
    else
        NoclipBtn.Text = "🚫 NOCLIP OFF"
        NoclipBtn.BackgroundColor3 = Color3.new(0.5, 0, 0.5)
        Status.Text = "Noclip выключен"
    end
end

